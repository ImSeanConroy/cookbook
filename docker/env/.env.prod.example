# -------------------------
# APP (internal)
# -------------------------
READ_ONLY=true
LOG_LEVEL=info

# -------------------------
# EXTERNAL PORTS (HOST MACHINE)
# -------------------------
FRONTEND_PORT=80
BACKEND_PORT=5000
POSTGRES_PORT=5432

# -------------------------
# DATABASE
# -------------------------
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme
POSTGRES_DB=cookbook
POSTGRES_HOST=postgres

# -------------------------
# URLS
# -------------------------
FRONTEND_ORIGIN=https://your-domain.com
BACKEND_URL=https://your-domain.com

# -------------------------
# FRONTEND (VITE - INJECTED AT CONTAINER RUNTIME VIA ENVSUBST)
# -------------------------
VITE_BASE_URL=https://your-domain.com/api
VITE_READ_ONLY=false